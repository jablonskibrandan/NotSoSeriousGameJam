[sub_resource type="Shader" id="Shader_si1ts"]
code = "shader_type spatial;
render_mode blend_mix, depth_draw_opaque, depth_test_default, cull_front, diffuse_lambert, specular_schlick_ggx;

uniform sampler2D glitter_texture;
uniform float glitter_metallic = 0.795;
uniform float glitter_roughness = 0.455;

uniform float shader_mix = 0.9;

uniform sampler2D dot_texture;
uniform sampler2D dot_metallic;
uniform sampler2D dot_roughness;

void fragment() {
	vec3 tex = texture(glitter_texture, UV).rgb;
	vec3 tex2 = texture(dot_texture, UV).rgb;
	
	float dot_met = texture(dot_metallic, UV).r;
	float dot_rough = texture(dot_roughness, UV).r;
	
	ALBEDO = mix(tex, tex2, shader_mix);
	METALLIC =  mix(glitter_metallic, dot_met, shader_mix);
	ROUGHNESS =  mix(glitter_roughness, dot_rough, shader_mix) ;
	
}"

