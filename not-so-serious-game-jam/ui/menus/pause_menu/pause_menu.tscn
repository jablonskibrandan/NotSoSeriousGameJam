[gd_scene load_steps=5 format=3]

[ext_resource type="Script" path="res://ui/menus/pause_menu/pause_menu.gd" id="1_scr"]
[ext_resource type="AudioStream" path="res://assets/audio/ui/hover.ogg" id="2_hov"]
[ext_resource type="AudioStream" path="res://assets/audio/ui/click.ogg" id="3_clk"]
[ext_resource type="FontFile" path="res://assets/fonts/oswald/static/Oswald-SemiBold.ttf" id="4_fnt"]
[ext_resource type="FontFile" path="res://assets/fonts/oswald/static/Oswald-Light.ttf" id="5_lgt"]

[sub_resource type="StyleBoxEmpty" id="StyleBoxEmpty_empty"]

[node name="PauseMenu" type="Control"]
process_mode = 3
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_scr")

[node name="Overlay" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
mouse_filter = 2
color = Color(0, 0, 0, 0.65)

[node name="LeftPanel" type="MarginContainer" parent="."]
layout_mode = 1
anchors_preset = 9
anchor_right = 0.0
anchor_bottom = 1.0
offset_right = 460.0
grow_vertical = 2
theme_override_constants/margin_left = 80
theme_override_constants/margin_top = 80
theme_override_constants/margin_bottom = 80

[node name="VBox" type="VBoxContainer" parent="LeftPanel"]
layout_mode = 2
theme_override_constants/separation = 0

[node name="PausedLabel" type="Label" parent="LeftPanel/VBox"]
layout_mode = 2
theme_override_fonts/font = ExtResource("5_lgt")
theme_override_font_sizes/font_size = 80
text = "PAUSED"

[node name="TitleSep" type="HSeparator" parent="LeftPanel/VBox"]
layout_mode = 2
modulate = Color(1, 1, 1, 0.15)

[node name="ButtonSpacer" type="Control" parent="LeftPanel/VBox"]
custom_minimum_size = Vector2(0, 32)
layout_mode = 2

[node name="ResumeButton" type="Button" parent="LeftPanel/VBox" groups=["pause_buttons"]]
unique_name_in_owner = true
modulate = Color(1, 1, 1, 0.38)
layout_mode = 2
focus_mode = 2
theme_override_colors/font_color = Color(1, 1, 1, 1)
theme_override_colors/font_hover_color = Color(1, 1, 1, 1)
theme_override_colors/font_pressed_color = Color(1, 1, 1, 1)
theme_override_colors/font_focus_color = Color(1, 1, 1, 1)
theme_override_fonts/font = ExtResource("5_lgt")
theme_override_font_sizes/font_size = 42
theme_override_styles/focus = SubResource("StyleBoxEmpty_empty")
theme_override_styles/hover = SubResource("StyleBoxEmpty_empty")
theme_override_styles/pressed = SubResource("StyleBoxEmpty_empty")
theme_override_styles/normal = SubResource("StyleBoxEmpty_empty")
text = "RESUME"
flat = true
alignment = 0

[node name="RestartButton" type="Button" parent="LeftPanel/VBox" groups=["pause_buttons"]]
unique_name_in_owner = true
modulate = Color(1, 1, 1, 0.38)
layout_mode = 2
focus_mode = 2
theme_override_colors/font_color = Color(1, 1, 1, 1)
theme_override_colors/font_hover_color = Color(1, 1, 1, 1)
theme_override_colors/font_pressed_color = Color(1, 1, 1, 1)
theme_override_colors/font_focus_color = Color(1, 1, 1, 1)
theme_override_fonts/font = ExtResource("5_lgt")
theme_override_font_sizes/font_size = 42
theme_override_styles/focus = SubResource("StyleBoxEmpty_empty")
theme_override_styles/hover = SubResource("StyleBoxEmpty_empty")
theme_override_styles/pressed = SubResource("StyleBoxEmpty_empty")
theme_override_styles/normal = SubResource("StyleBoxEmpty_empty")
text = "RESTART"
flat = true
alignment = 0



[node name="OptionsButton" type="Button" parent="LeftPanel/VBox" groups=["pause_buttons"]]
unique_name_in_owner = true
modulate = Color(1, 1, 1, 0.38)
layout_mode = 2
focus_mode = 2
theme_override_colors/font_color = Color(1, 1, 1, 1)
theme_override_colors/font_hover_color = Color(1, 1, 1, 1)
theme_override_colors/font_pressed_color = Color(1, 1, 1, 1)
theme_override_colors/font_focus_color = Color(1, 1, 1, 1)
theme_override_fonts/font = ExtResource("5_lgt")
theme_override_font_sizes/font_size = 42
theme_override_styles/focus = SubResource("StyleBoxEmpty_empty")
theme_override_styles/hover = SubResource("StyleBoxEmpty_empty")
theme_override_styles/pressed = SubResource("StyleBoxEmpty_empty")
theme_override_styles/normal = SubResource("StyleBoxEmpty_empty")
text = "OPTIONS"
flat = true
alignment = 0

[node name="GuideButton" type="Button" parent="LeftPanel/VBox" groups=["pause_buttons"]]
unique_name_in_owner = true
visible = false
modulate = Color(1, 1, 1, 0.38)
layout_mode = 2
focus_mode = 0
theme_override_colors/font_color = Color(1, 1, 1, 1)
theme_override_colors/font_hover_color = Color(1, 1, 1, 1)
theme_override_colors/font_pressed_color = Color(1, 1, 1, 1)
theme_override_colors/font_focus_color = Color(1, 1, 1, 1)
theme_override_fonts/font = ExtResource("5_lgt")
theme_override_font_sizes/font_size = 42
theme_override_styles/focus = SubResource("StyleBoxEmpty_empty")
theme_override_styles/hover = SubResource("StyleBoxEmpty_empty")
theme_override_styles/pressed = SubResource("StyleBoxEmpty_empty")
theme_override_styles/normal = SubResource("StyleBoxEmpty_empty")
text = "GUIDE"
flat = true
alignment = 0

[node name="MainMenuButton" type="Button" parent="LeftPanel/VBox" groups=["pause_buttons"]]
unique_name_in_owner = true
modulate = Color(1, 1, 1, 0.38)
layout_mode = 2
focus_mode = 0
theme_override_colors/font_color = Color(1, 1, 1, 1)
theme_override_colors/font_hover_color = Color(1, 1, 1, 1)
theme_override_colors/font_pressed_color = Color(1, 1, 1, 1)
theme_override_colors/font_focus_color = Color(1, 1, 1, 1)
theme_override_fonts/font = ExtResource("5_lgt")
theme_override_font_sizes/font_size = 42
theme_override_styles/focus = SubResource("StyleBoxEmpty_empty")
theme_override_styles/hover = SubResource("StyleBoxEmpty_empty")
theme_override_styles/pressed = SubResource("StyleBoxEmpty_empty")
theme_override_styles/normal = SubResource("StyleBoxEmpty_empty")
text = "MAIN MENU"
flat = true
alignment = 0

[node name="VertStretch" type="Control" parent="LeftPanel/VBox"]
layout_mode = 2
size_flags_vertical = 3

[node name="ExitButton" type="Button" parent="LeftPanel/VBox" groups=["pause_buttons"]]
unique_name_in_owner = true
modulate = Color(1, 1, 1, 0.38)
layout_mode = 2
focus_mode = 0
theme_override_colors/font_color = Color(1, 1, 1, 1)
theme_override_colors/font_hover_color = Color(1, 1, 1, 1)
theme_override_colors/font_pressed_color = Color(1, 1, 1, 1)
theme_override_colors/font_focus_color = Color(1, 1, 1, 1)
theme_override_fonts/font = ExtResource("5_lgt")
theme_override_font_sizes/font_size = 32
theme_override_styles/focus = SubResource("StyleBoxEmpty_empty")
theme_override_styles/hover = SubResource("StyleBoxEmpty_empty")
theme_override_styles/pressed = SubResource("StyleBoxEmpty_empty")
theme_override_styles/normal = SubResource("StyleBoxEmpty_empty")
text = "EXIT GAME"
flat = true
alignment = 0

[node name="SFX" type="Node" parent="."]
process_mode = 3

[node name="Hover" type="AudioStreamPlayer" parent="SFX"]
stream = ExtResource("2_hov")
bus = &"SFX"

[node name="Click" type="AudioStreamPlayer" parent="SFX"]
stream = ExtResource("3_clk")
bus = &"SFX"

[connection signal="pressed" from="LeftPanel/VBox/ResumeButton" to="." method="_on_resume_pressed"]
[connection signal="pressed" from="LeftPanel/VBox/RestartButton" to="." method="_on_restart_pressed"]
[connection signal="pressed" from="LeftPanel/VBox/LoadButton" to="." method="_on_load_pressed"]
[connection signal="pressed" from="LeftPanel/VBox/OptionsButton" to="." method="_on_options_pressed"]
[connection signal="pressed" from="LeftPanel/VBox/GuideButton" to="." method="_on_guide_pressed"]
[connection signal="pressed" from="LeftPanel/VBox/MainMenuButton" to="." method="_on_main_menu_pressed"]
[connection signal="pressed" from="LeftPanel/VBox/ExitButton" to="." method="_on_exit_pressed"]
