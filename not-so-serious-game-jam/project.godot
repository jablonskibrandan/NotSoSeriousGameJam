; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="NotSoSeriousGameJam"
run/main_scene="res://ui/main_scene/main_scene.tscn"
config/features=PackedStringArray("4.7", "Forward Plus")
config/icon="res://icon.svg"

[audio]

buses/default_bus_layout="uid://j5h6apvngair"

[autoload]

GameManagerObject="*uid://tpffp0y3vhg4"
Console="*uid://ouiu5xh1cs8n"
Bus="*res://autoloads/Bus.gd"
SceneManager="*res://autoloads/scene_manager.tscn"
SettingsManager="*res://autoloads/settings_manager.gd"
UIConstants="*res://ui/shared/ui_constants.gd"
MusicManager="*res://autoloads/music_manager.tscn"
EndingManager="*res://autoloads/ending_manager.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=2
window/stretch/mode="canvas_items"
mouse_cursor/custom_image="uid://b3cvmvexkuwji"

[editor_plugins]

enabled=PackedStringArray("res://addons/console/plugin.cfg")

[file_customization]

folder_colors={
"res://Assets/camera/": "orange",
"res://Assets/planet/": "orange",
"res://Assets/planet2/": "orange"
}

